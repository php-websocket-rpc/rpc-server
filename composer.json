{
    "name": "php-websocket-rpc/rpc-server",
    "description": "Async RPC server over WebSocket using amphp and msgpack",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Prasetyo Wicaksono",
            "email": "pras@tuta.io"
        }
    ],
    "keywords": ["rpc", "websocket", "amphp", "async", "msgpack", "server", "rate-limiter"],
    "homepage": "https://github.com/php-websocket-rpc/rpc-server",
    "support": {
        "issues": "https://github.com/php-websocket-rpc/php-websocket-rpc/issues"
    },
    "require": {
        "php": ">=8.5",
        "ext-msgpack": "*",
        "amphp/amp": "^3",
        "amphp/websocket-server": "^4",
        "amphp/http-server": "^3",
        "amphp/http-server-router": "^2",
        "psr/log": "^3",
        "php-websocket-rpc/rpc": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11"
    },
    "autoload": {
        "psr-4": {
            "PhpWebsocketRpc\\RpcServer\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpWebsocketRpc\\RpcServer\\Tests\\": "Tests/"
        }
    }
}
